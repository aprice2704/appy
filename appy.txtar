	os.WriteFile(targetFile, []byte(initialContent), 0644)

	payload := Payload{
		Bundle: strings.ReplaceAll(`
### filename: target.go
### replace
func Old() {}
### with
func New() {}
### end
`, "###", patcheng.BundleDelim),
	}
	body, _ := json.Marshal(payload)

	req := httptest.NewRequest(http.MethodPost, "/api/apply", bytes.NewReader(body))
